# Copy to keystore.properties (gitignored) and fill in your real values to sign release builds.
#
# 1. Generate a release keystore (keep the resulting .jks + these passwords safe — losing them
#    means you can never ship an update to the same Play listing):
#
#      keytool -genkeypair -v \
#        -keystore snackpilot-release.jks \
#        -alias snackpilot \
#        -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Point storeFile at that .jks (path relative to src/android/) and set the passwords/alias below.
# 3. `./gradlew assembleRelease` (or bundleRelease) will then produce a signed artifact.

storeFile=snackpilot-release.jks
storePassword=CHANGE_ME
keyAlias=snackpilot
keyPassword=CHANGE_ME
