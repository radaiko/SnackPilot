{
  "name": "snackpilot-icon-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Dev-only tool for generating and rendering SnackPilot app icons. Isolated from src/app so sharp is not shipped to EAS builds.",
  "scripts": {
    "generate": "tsx generate-icons.ts",
    "render": "tsx render-icons.ts",
    "all": "tsx generate-icons.ts && tsx render-icons.ts"
  },
  "dependencies": {
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
